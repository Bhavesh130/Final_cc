# Required: OpenRouter API key for the AI chat assistant.
# (OPEN_ROUTER_API_KEY is also accepted as an alias.)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Massive (Polygon.io) API key for real market data.
# Leave empty to use the built-in GBM market simulator (recommended).
MASSIVE_API_KEY=

# Optional: deterministic mock LLM responses (no API calls). Useful for tests.
LLM_MOCK=false
